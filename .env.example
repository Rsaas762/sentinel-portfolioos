# ===========================================================================
# Sentinel PortfolioOS — environment variables
# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. EVERY variable here is OPTIONAL:
# with none set, the app runs in zero-config demo mode (seed data, no auth).
# Add Supabase to enable the live CMS; add Anthropic to enable real AI drafts.
# NEVER commit `.env.local`. Only NEXT_PUBLIC_* values reach the browser.
# ===========================================================================

# --- Supabase (enables the live database + admin auth + RLS) ---------------
# Found in your Supabase project: Settings -> API.
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Anthropic (enables AI-written case-study drafts) ----------------------
# Without this, the assistant uses the built-in deterministic templates.
# This is SERVER-ONLY — never prefix it with NEXT_PUBLIC.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8):
ANTHROPIC_MODEL=claude-opus-4-8

# --- Email notifications (Resend) ------------------------------------------
# When set, a notification email is sent to your contact_email on each new
# contact-form submission (reply-to is the sender). Without it, messages are
# still stored in the admin inbox. Get a key at https://resend.com (free tier).
RESEND_API_KEY=
# From address. Use the default until you verify your own domain in Resend.
EMAIL_FROM=Portfolio <onboarding@resend.dev>

# --- Security / privacy ----------------------------------------------------
# Server-only salt used to hash contact-form IP addresses (data minimisation).
# Generate a random value, e.g. `openssl rand -hex 32`.
IP_HASH_SALT=

# --- Site metadata ---------------------------------------------------------
# Used for absolute URLs in metadata / Open Graph. Optional.
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com
